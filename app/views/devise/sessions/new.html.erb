<div class="login-card">
  <h2 class="login-title">Log In</h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { data: { turbo: false } }) do |f| %>
    <div class="form-group">
      <%= f.label :email %>
      <%= f.email_field :email, autofocus: true, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label :password %>
      <%= f.password_field :password, autocomplete: "off", class: "form-input" %>
    </div>

    <% if devise_mapping.rememberable? -%>
      <div class="form-checkbox">
        <%= f.check_box :remember_me %>
        <%= f.label :remember_me %>
      </div>
    <% end -%>

    <div class="form-actions">
      <%= f.submit "Log in", class: "button" %>
    </div>
  <% end %>
</div>
